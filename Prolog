cat SetOperations.pl
% 1. Union: Combining two sets without duplicates
union([], L, L).
union([H|T], L, [H|Res]) :-
    \+ member(H, L),
    union(T, L, Res).
union([H|T], L, Res) :-
    member(H, L),
    union(T, L, Res).

% 2. Intersection: Elements present in both sets
intersection([], _, []).
intersection([H|T], L, [H|Res]) :-
    member(H, L),
    intersection(T, L, Res).
intersection([H|T], L, Res) :-
    \+ member(H, L),
    intersection(T, L, Res).

% 3. Subset: Checks if all elements of S1 are in S2
subset([], _).
subset([H|T], L) :-
    member(H, L),
    subset(T, L).

% 4. Cardinality: Number of elements in a set
cardinality([], 0).
cardinality([_|T], N) :-
    cardinality(T, N1),
    N is N1 + 1.

% 5. Equivalent: Sets have the same elements (mutual subsets)
equivalent(S1, S2) :-
    subset(S1, S2),
    subset(S2, S1).

% 6. Difference: Elements in S1 but not in S2
difference([], _, []).
difference([H|T], L, [H|Res]) :-
    \+ member(H, L),
    difference(T, L, Res).
difference([H|T], L, Res) :-
    member(H, L),
    difference(T, L, Res).
