cat Calculator.pl
calculate(+,A,B,R):- R is A + B.
calculate(-,A,B,R):- R is A - B.
calculate(*,A,B,R):- R is A * B.
calculate(/,A,B,R):- B =\= 0, R is A / B.
calculate(mod,A,B,R):- B =\= 0, R is A mod B.

menu :-
    write('1.add 2.sub 3.mul 4.div 5.mod 6.exit'), nl,
    read(Ch),
    (Ch == 6 -> write('Exiting...');
        write('Enter 1st number: '), read(A),
        write('Enter 2nd number: '), read(B),
        process(Ch, A, B)).

process(1, A, B) :- calculate(+, A, B, R), write('Result: '), write(R).
process(2, A, B) :- calculate(-, A, B, R), write('Result: '), write(R).
process(3, A, B) :- calculate(*, A, B, R), write('Result: '), write(R).
process(4, A, B) :- calculate(/, A, B, R), write('Result: '), write(R).
process(5, A, B) :- calculate(mod, A, B, R), write('Result: '), write(R).
process(_, _, _) :- write('Invalid choice').

